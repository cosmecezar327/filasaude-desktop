<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10"
      xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.com.ccs.filasaude.controller.PacienteControllerFX">
	<padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <GridPane hgap="10" vgap="10">

    <Label text="Nome"
           GridPane.rowIndex="0"
           GridPane.columnIndex="0"/>

    <TextField fx:id="txtNome"
               prefWidth="250"
               GridPane.rowIndex="0"
               GridPane.columnIndex="1"/>

    <Label text="CPF"
           GridPane.rowIndex="1"
           GridPane.columnIndex="0"/>

    <TextField fx:id="txtCpf"
               prefWidth="250"
               GridPane.rowIndex="1"
               GridPane.columnIndex="1"/>

    <Label text="Idade"
           GridPane.rowIndex="2"
           GridPane.columnIndex="0"/>

    <TextField fx:id="txtIdade"
               prefWidth="100"
               GridPane.rowIndex="2"
               GridPane.columnIndex="1"/>

</GridPane>

    <Label text="Sexo"/>

    <HBox spacing="10">
        <RadioButton fx:id="rbMasculino" text="Masculino"/>
        <RadioButton fx:id="rbFeminino" text="Feminino"/>
    </HBox>

    <Label text="Condições"/>

    <HBox spacing="10">
        <CheckBox fx:id="cbDiabetes" text="Diabetes"/>
        <CheckBox fx:id="cbHipertensao" text="Hipertensão"/>
        <CheckBox fx:id="cbCardiaco" text="Cardíaco"/>
    </HBox>

    <CheckBox fx:id="cbAtivo"
              text="Paciente Ativo"
              selected="true"/>

   <HBox spacing="10">
    <Button text="Salvar"
            prefWidth="100"
            onAction="#salvar"/>

    <Button text="Limpar"
            prefWidth="100"
            onAction="#limpar"/>
</HBox>

</VBox>